# Copy this to .env and fill in values

# Database — SQLite (default, no Docker needed)
DATABASE_URL=sqlite+aiosqlite:///./urbanpulse.db

# Database — PostgreSQL via Docker
# DATABASE_URL=postgresql+asyncpg://urbanpulse:secret@localhost:5432/urbanpulse

# Redis (optional — leave empty to use in-memory fallback)
REDIS_URL=

# OpenAQ API (optional — improves rate limits; register free at openaq.org)
OPENAQ_API_KEY=

# Admin API token
ADMIN_TOKEN=changeme-in-production

# App settings
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=300
INGEST_INTERVAL_MINUTES=60
RETRAIN_INTERVAL_HOURS=24
